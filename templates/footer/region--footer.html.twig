{% if content %}
    <div class="py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-10">
                    {{ elements.lookatmedia_footer }}
                    {{ elements.copyrighttext }}
                </div>
                <div class="col-md-2">
                    {{ elements.footerlogo }}
                </div>
            </div>
        </div>
    </div>
      <div id="mybutton">
        <button class="feedback open-modal" >Book a demo</button>
    </div>
  <div class="modal hide">
    <div class="modal-container hide">
      <div class="modal-header">
        <h2></h2><button class="close-modal"><i class="fas fa-times"></i></button>
      </div>
      <div class="modal-content">
        <iframe class="responsive-iframe" id="acuity-modal-frame" src="https://lookatme.as.me/lookatmedia" frameborder="0" style="max-width: 100%;" width="900" height="800"></iframe>
        
      </div>
    </div>
  </div>

{% endif %}
