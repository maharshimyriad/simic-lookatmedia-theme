<div class="container">
    {% if title %}
    <h3>{{ title }}</h3>
    {% endif %}
    <div class="row minihome-rows">
        {% for row in rows %}
        {%
            set row_classes = [
            default_row_class ? 'views-row',
            ]
        %}
        <div{{ row.attributes.addClass(row_classes) }}>
            {{- row.content -}}
        </div>
        {% endfor %}
    </div>
</div>