<div class="container">
  {% if title %}
    <h3>{{ title }}</h3>
  {% endif %}
  {% set loop_index = 1 %}
  {% for row in rows %}
    {%
      set row_classes = [
        default_row_class ? 'views-row',
        loop_index % 2 == 0 ? 'banner-mirror',
      ]
    %}
    <div{{ row.attributes.addClass(row_classes) }} data-row="{{ row.index }}">
      {{- row.content -}}
    </div>
    {% set loop_index = loop_index + 1 %}
  {% endfor %}
</div>